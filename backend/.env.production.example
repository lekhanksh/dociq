ENV=production
DATABASE_URL=postgresql://<user>:<password>@<aurora-writer-endpoint>:5432/dociq
VECTOR_BACKEND=pgvector
JWT_SECRET=load-from-secrets-manager
S3_BUCKET_NAME=your-company-documents-prod
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
CORS_ORIGINS=https://app.your-domain.com
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS_PER_WINDOW=90
AUDIT_LOG_PATH=/var/log/dociq/audit.prod.log
