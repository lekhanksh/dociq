ENV=staging
DATABASE_URL=postgresql://<user>:<password>@<aurora-writer-endpoint>:5432/dociq
VECTOR_BACKEND=pgvector
JWT_SECRET=load-from-ssm-or-secrets-manager
S3_BUCKET_NAME=your-company-documents-staging
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
CORS_ORIGINS=https://staging.your-domain.com
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS_PER_WINDOW=120
AUDIT_LOG_PATH=/var/log/dociq/audit.staging.log
