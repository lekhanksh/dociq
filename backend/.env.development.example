ENV=development
DATABASE_URL=sqlite:///./dociq.db
VECTOR_BACKEND=memory
JWT_SECRET=replace-with-local-dev-secret
S3_BUCKET_NAME=your-company-documents-dev
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS_PER_WINDOW=200
AUDIT_LOG_PATH=./logs/audit.dev.log
