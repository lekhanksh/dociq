# Copy to .env.staging or .env.prod — never commit real values
ENV=development

# Database
DATABASE_URL=postgresql://dociq:password@localhost:5432/dociq_dev

# AWS
AWS_REGION=us-east-1
S3_BUCKET_NAME=dociq-documents-staging

# Secrets (local dev only — prod uses Secrets Manager)
JWT_SECRET=local-dev-secret-minimum-32-characters-long
JWT_EXPIRY_HOURS=24

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
